{
    "manifest_version": 3,
    "name": "PhobiaBlocker",
    "version": "1.2.0",
    "description": "Blur likely phobia triggers on web pages with smart text analysis, quick controls, and custom site rules.",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_popup": "popup.html",
        "default_title": "PhobiaBlocker"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["js/early-blur.js"],
            "css": ["css/early-blur.css"],
            "all_frames": true,
            "run_at": "document_start"
        },
        {
            "matches": ["<all_urls>"],
            "js": ["js/js.js"],
            "css": ["css/style.css"],
            "all_frames": true,
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [{
        "resources": ["css/style.css"],
        "matches": ["<all_urls>"]
    }],
    "background": {
        "service_worker": "js/background.js"
    },
    "options_ui": {
        "page": "settings.html",
        "open_in_tab": true
    },
    "commands": {
        "blur-all": {
            "suggested_key": {
                "default": "Alt+Shift+B",
                "mac": "Alt+Shift+B"
            },
            "description": "Blur all images on the page"
        },
        "unblur-all": {
            "suggested_key": {
                "default": "Alt+Shift+U",
                "mac": "Alt+Shift+U"
            },
            "description": "Unblur all images on the page"
        }
    },
    "permissions": [
        "contextMenus",
        "offscreen",
        "storage"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ]
}
